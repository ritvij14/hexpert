# @hexpert/agent — local dev env. Copy to .env and fill in. Never commit .env.
# See docs/prds/prd.md §8 for the full reference.

# Etherscan API key — wallet + contract source tools (Lambda env).
ETHERSCAN_API_KEY=

# Public Ethereum RPC URL for ENS forward/reverse resolution (wallet subgraph).
# No API key, no cost. Must support ENS universal-resolver CCIP-read gateways.
# Default: ethereum.publicnode.com (confirmed both directions). eth.drpc.org also
# works. Cloudflare's gateway does NOT (returns "Internal error"). Override if
# rate-limited or down.
ETH_RPC_URL=https://ethereum.publicnode.com

# CORS origin whitelist — the Vercel/Next.js origin. Local dev: http://localhost:3000
ALLOWED_ORIGIN=http://localhost:3000

# Upstash (or local) Redis URL for the TTL-evicted HITL checkpointer (ADR-008).
REDIS_URL=

# Checkpoint TTL in minutes; abandoned HITL checkpoints auto-expire. Default 60.
REDIS_TTL_MINUTES=60

# LOCAL DEV ONLY — fallback for missing X-Api-Key / X-Search-Key headers so the
# pipeline can be smoke-tested with curl without pasting keys into each request.
# Guarded by !AWS_LAMBDA_FUNCTION_NAME in src/middleware/extractHeaders.ts: this
# fallback is DEAD on Lambda and these vars must NEVER be set in the Lambda
# environment — Lambda always requires the BYOK headers (PRD §4.3).
LOCAL_DEV_API_KEY=
LOCAL_DEV_SEARCH_KEY=