# Hexpert — local development environment template.
# Copy to `.env` and fill in values. `.env` is gitignored and NEVER committed.
# In CI there is no `.env` file; the same variables are sourced from the CI
# environment (GitHub Secrets → env). Tests load this file with `override:false`
# (apps/agent/test/setup.ts), so a real shell/CI env always wins over `.env`.
#
# Nothing here is required to run the test suite: unit/integration/harness tests
# need no keys, and the flow test mocks the LLM + Redis boundaries. The values
# below are for running the agent locally (`npm -w @hexpert/agent run dev`) and
# for real-BYOK evals added later.

# --- Agent runtime config (mirrors infrastructure/template.yaml parameters) ---

# CORS origin the agent allows (the frontend domain). Captured at app start.
ALLOWED_ORIGIN=https://hexpert.ritvij.dev

# Upstash (or other) Redis URL for the TTL-evicted HITL checkpointer (ADR-008).
# Optional locally — the agent starts without it; /api/chat HITL resume needs it.
REDIS_URL=
REDIS_TTL_MINUTES=60

# Public Ethereum RPC for ENS forward/reverse resolution (wallet subgraph).
ETH_RPC_URL=https://ethereum.publicnode.com

# Etherscan API key (wallet + contract tools). Free tier.
ETHERSCAN_API_KEY=

# --- Local-dev BYOK fallback (off-Lambda ONLY; NEVER set these in the Lambda env) ---
# When running locally (not on Lambda), missing X-Api-Key / X-Search-Key request
# headers fall back to these, so the pipeline can be smoke-tested with curl
# without pasting keys into every request. See apps/agent/src/middleware/extractHeaders.ts.

LOCAL_DEV_API_KEY=
LOCAL_DEV_SEARCH_KEY=

# --- Real-LLM evals (on-demand, local ONLY; see evals/README.md) ---
# Run with `npm run eval` / `npm run eval:router` / `npm run eval:audit`.
# These use YOUR keys and SPEND TOKENS. They are NOT part of `npm test` and
# never run in CI. REDIS_URL (above) is also required — buildMainGraph calls
# getCheckpointer() unconditionally, so every eval turn needs the checkpointer
# initialized, even single-turn router cases.
#
# EVAL_PROVIDER must be one of: openai | anthropic | openrouter | ollama
# EVAL_SEARCH_KEY must be a Tavily key starting with "tvly-".
EVAL_PROVIDER=openai
EVAL_MODEL=gpt-4o-mini
EVAL_API_KEY=
EVAL_SEARCH_KEY=

# --- QnA eval LLM-as-judge (optional; see evals/README.md) --------------------
# The qna eval grades prose answers with a second LLM. By default the judge
# reuses EVAL_PROVIDER / EVAL_MODEL / EVAL_API_KEY (one key, one model — simple).
# Set these to a STRONGER model to grade answer quality more reliably. Leaving
# them unset is fine. See docs/infra/risks.md R7 (parked decision).
# EVAL_JUDGE_PROVIDER=anthropic
# EVAL_JUDGE_MODEL=claude-sonnet-4-6
# EVAL_JUDGE_API_KEY=

# --- Wallet eval (wallet.eval.ts) --------------------------------------------
# Hits real Etherscan + ENS RPC. ETHERSCAN_API_KEY (above) is required; the
# wallet subgraph calls fetchTransactions / fetchTokenHoldings against it.